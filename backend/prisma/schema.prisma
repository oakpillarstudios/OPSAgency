datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String         @id @default(uuid())
  googleId         String?        @unique
  name             String
  email            String         @unique
  password         String?
  phone            String?
  whatsApp         String?
  profilePhoto     String?
  company          String?
  businessType     String?
  industry         String?
  website          String?
  city             String?
  country          String?
  role             String         @default("USER") // "USER", "ADMIN", "SUPER_ADMIN"
  leadScore        Int            @default(0)
  disabled         Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  
  // Relations
  savedServices    SavedService[]
  savedTemplates   SavedTemplate[]
  activities       LeadActivity[]
  quotes           QuoteRequest[]
  consultations    Consultation[]
  notifications    Notification[]
  contactRequests  ContactRequest[]
}

model ServiceCategory {
  id          String    @id @default(uuid())
  slug        String    @unique
  name        String
  services    Service[]
}

model Service {
  id               String          @id @default(uuid())
  categoryId       String
  category         ServiceCategory @relation(fields: [categoryId], references: [id])
  slug             String          @unique
  title            String
  shortDesc        String
  longDesc         String?
  features         String          // JSON-string list of features
  timeline         String
  priceFrom        Float
  priceTo          Float?
  featuredImage    String
  techStack        String          // JSON-string list of technologies
  popular          Boolean         @default(false)
  featured         Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  
  savedBy          SavedService[]
}

model Template {
  id               String          @id @default(uuid())
  slug             String          @unique
  name             String
  category         String
  industry         String
  description      String
  technology       String
  primaryColor     String
  thumbnail        String
  gallery          String          // JSON-string list of preview images
  responsive       Boolean         @default(true)
  seoReady         Boolean         @default(true)
  perfScore        Int             @default(98)
  accessScore      Int             @default(100)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  
  savedBy          SavedTemplate[]
}

model SavedService {
  id        String   @id @default(uuid())
  userId    String
  serviceId String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  
  @@unique([userId, serviceId])
}

model SavedTemplate {
  id         String   @id @default(uuid())
  userId     String
  templateId String
  createdAt  DateTime @default(now())
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  @@unique([userId, templateId])
}

model LeadActivity {
  id        String   @id @default(uuid())
  userId    String
  action    String   // "LOGIN", "VIEW_SERVICE", "VIEW_TEMPLATE", "QUOTE_REQUEST", etc.
  details   String?
  timestamp DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuoteRequest {
  id           String     @id @default(uuid())
  userId       String
  serviceName  String
  templateName String?
  budget       Float
  timeline     String
  requirements String
  status       String     @default("NEW") // "NEW", "CONTACTED", "INTERESTED", "MEETING_SCHEDULED", "PROPOSAL_SENT", "WON", "LOST", "ARCHIVED"
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Consultation {
  id            String     @id @default(uuid())
  userId        String
  preferredDate DateTime
  preferredTime String
  timezone      String
  contactMethod String     // "GOOGLE_MEET", "ZOOM", "WHATSAPP", "PHONE"
  notes         String?
  status        String     @default("NEW")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  type        String   // "INFO", "ALERT", "QUOTE_UPDATE"
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Blog {
  id            String   @id @default(uuid())
  slug          String   @unique
  title         String
  excerpt       String
  content       String
  featuredImg   String
  author        String
  category      String
  readingTime   Int
  views         Int      @default(0)
  publishedDate DateTime @default(now())
  status        String   @default("PUBLISHED") // "DRAFT", "PUBLISHED"
}

model FAQ {
  id        String @id @default(uuid())
  category  String
  question  String
  answer    String
}

model Testimonial {
  id          String   @id @default(uuid())
  clientName  String
  company     String
  designation String
  photo       String
  rating      Int      @default(5)
  review      String
  industry    String
  projectType String
  location    String
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Portfolio {
  id           String   @id @default(uuid())
  projectName  String
  client       String
  industry     String
  gallery      String   // JSON-string list of images
  projectStory String
  challenges   String
  solutions    String
  technologies String   // JSON-string list
  perfScore    Int      @default(98)
  seoScore     Int      @default(100)
  clientReview String?
  clientPhoto  String?
  clientName   String?
  clientRole   String?
  featured     Boolean  @default(false)
  slug         String   @unique
  createdAt    DateTime @default(now())
}

model Analytics {
  id               String   @id @default(uuid())
  date             DateTime @default(now())
  dailyVisitors    Int      @default(0)
  returningVisitors Int      @default(0)
  bounceRate       Float    @default(0)
  avgSession       Float    @default(0)
  topServices      String   // JSON-string ranking
  topTemplates     String   // JSON-string ranking
  topSearches      String   // JSON-string keywords
  conversions      Int      @default(0)
}

model WebsiteSettings {
  id               String @id @default(uuid())
  logo             String
  favicon          String
  companyName      String
  email            String
  phone            String
  whatsApp         String
  address          String
  businessHours    String
  socialLinks      String // JSON-string of links
  footerText       String
  announcementBar  String
  themeColors      String // JSON-string of theme values
  defaultSeo       String // JSON-string of tags
}

model MediaLibrary {
  id        String   @id @default(uuid())
  name      String
  type      String   // "IMAGE", "VIDEO", "PDF", "SVG"
  url       String
  folder    String   @default("uploads")
  tags      String?
  sizeBytes Int
  createdAt DateTime @default(now())
}

model ContactRequest {
  id               String   @id @default(uuid())
  userId           String?
  name             String
  email            String
  phone            String
  company          String?
  selectedService  String?
  selectedTemplate String?
  requirements     String
  source           String   @default("Direct") // "Google Search", "Facebook", etc.
  status           String   @default("NEW")    // "NEW", "CONTACTED", "ARCHIVED"
  notes            String?
  createdAt        DateTime @default(now())

  user             User?    @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  user      String   // Email or Username
  ip        String?
  browser   String?
  action    String
  timestamp DateTime @default(now())
}
